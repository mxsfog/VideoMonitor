# Safe example only. Do not commit real keys or credentials.

COURSEWORK_LLM_BACKEND=none
COURSEWORK_LLM_MODEL=qwen3.5:9b
COURSEWORK_PIPELINE_FPS=1.0
COURSEWORK_PIPELINE_SKIP=
COURSEWORK_WHISPER_MODEL=tiny
COURSEWORK_LANG=ru
COURSEWORK_SMB_MOUNT_ROOT=
COURSEWORK_HANDOVER_COMMAND=
COURSEWORK_ALLOW_HANDOVER_NOOP=
COURSEWORK_CORS_ORIGINS=

# Optional cloud VLM/OpenRouter mode.
OPENROUTER_API_KEY=

# Optional local model caches.
HF_HOME=models/hf
TORCH_HOME=models/torch
EASYOCR_MODULE_PATH=models/easyocr
YOLO_CONFIG_DIR=models/ultralytics
